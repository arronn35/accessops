{
  "name": "accessops",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "worker:dev": "WORKER_PROCESS=1 tsx --watch worker/index.ts",
    "worker:start": "WORKER_PROCESS=1 node --enable-source-maps worker/dist/index.js",
    "worker:build": "tsc -p worker/tsconfig.json",
    "queue:clean": "tsx scripts/queue-clean.ts",
    "scan:test": "tsx scripts/scan-test.ts",
    "report:test": "tsx scripts/report-test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "@auth/drizzle-adapter": "^1.11.2",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@axe-core/playwright": "^4.11.3",
    "@neondatabase/serverless": "^1.1.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "bullmq": "^5.76.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.21.0",
    "playwright": "^1.60.0",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "resend": "^6.12.3",
    "stripe": "^17.4.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.6",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
